# ytb2bili 配置文件示例（TOML格式）
# 复制此文件为 config.toml 并根据实际情况修改
# 注意：环境变量会覆盖此文件中的配置

# ============================================================================
# 应用基础配置
# ============================================================================

[server]
host = "0.0.0.0"           # 服务监听地址，0.0.0.0 表示监听所有网卡
port = 8096                # 服务端口
static_dir = "./downloads" # 静态文件目录（视频、字幕等）
static_path = "/static"    # 静态文件访问路径前缀

[auth]
jwt_secret = "change-this-local-jwt-secret"
access_token_ttl = 7200
refresh_token_ttl = 604800

# 可以自定义登录账号
[[auth.users]]
email = "admin@126.com"
password = "123456"




##  这里不要改
[api_auth]
enabled = false
app_id = "ytb2bili_extension"
app_secret = "ytb2bili_secret_2026"
cookies_decrypt_key = "59e7052041ce4bd6aff82f6a0bca9cde"


# ============================================================================
# 数据库配置
# ============================================================================
[database]
type = "mysql"
host = "mysql"                 # Docker Compose 服务名
port = 3306
user = "ytb2bili"              # 与 docker-compose.yml 一致
password = "ytb2bili@123"
dbname = "bili_up"             # 数据库名（注意是 dbname 不是 database）
sslmode = ""                   # MySQL 不使用（仅 PostgreSQL 需要）
timezone = "Asia/Shanghai"     # 时区配置
auto_migrate = true
table_prefix = ""



# ============================================================================
# 视频处理工作流配置
# ============================================================================
[workflow]
download_dir = "./downloads"  # 视频下载目录（必需，应与 server.static_dir 保持一致）

# yt-dlp 可执行文件路径（可选，默认从 PATH 查找）
ytdlp_path = "/usr/local/bin/yt-dlp"

# ffmpeg 可执行文件路径（可选，默认从 PATH 查找）
ffmpeg_path = "/usr/bin/ffmpeg"

# 水印字体文件路径（可选；用于非会员水印 drawtext fontfile）
watermark_font_file = "/app/fonts/watermark.ttf"


[llm]
provider = "deepseek"              # 服务商: openai, deepseek, ollama, qwen, zhipu, groq, custom
base_url = "https://api.deepseek.com"  # API 端点地址（OpenAI 兼容接口）
api_key = "sk-xxxxxxxxxxxx"
models = ["deepseek-v4-flash", "deepseek-chat", "deepseek-reasoner"] # 前端可选模型列表
temperature = 0.7                # 温度参数 (0.0-2.0)
max_tokens = 24096                # 每次请求最大 token 数
timeout = 300                    # 请求超时（秒）





# ============================================================================
# Azure TTS 语音合成配置（用户自行配置）
# ============================================================================
[azure_tts]
subscription_key = ""            # Azure Speech Services 订阅密钥
region = ""              # Azure 区域
