# ================================================================
# YTB2BILI 前端环境变量配置（仅开发环境需要）
# ================================================================
# 注意：生产构建时这些变量会被编译到静态文件中
#       用户运行时不需要配置这些变量
# ================================================================

# API Configuration
# 开发环境：指向本地后端服务
# 生产环境：留空（使用相对路径，自动适配部署域名）
NEXT_PUBLIC_API_URL=http://localhost:8096